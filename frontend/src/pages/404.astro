---
import Base from "../layouts/Base.astro";
---
<Base title="LinkPeru">
  <div class="container" style="padding: 3rem 1rem; max-width: 40rem; margin: 0 auto;">
    <div id="loading" class="text-center" style="padding: 4rem 0;">
      <p class="text-muted">Cargando...</p>
    </div>
    <div id="notFound" class="text-center hidden" style="padding: 4rem 0;">
      <div style="font-size: 4rem; margin-bottom: 1rem;">🔍</div>
      <h1 class="text-4xl font-bold mb-4">Página no encontrada</h1>
      <p class="text-xl text-muted mb-8">El enlace que buscas no existe.</p>
      <a href="/" class="btn btn-primary btn-pill">Ir al inicio</a>
    </div>
    <div id="profile" class="hidden">
      <div class="card text-center mb-6">
        <div id="avatar" style="width: 7rem; height: 7rem; margin: 0 auto 1.5rem; background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 2.5rem; font-weight: 700;"></div>
        <h1 class="text-2xl font-bold mb-1" id="profileName"></h1>
        <p class="text-muted mb-4" id="profileBio"></p>
        <button class="btn btn-outline btn-pill" style="font-size: 0.875rem;" id="shareBtn">📤 Compartir</button>
      </div>
      <div id="linksContainer" style="display: flex; flex-direction: column; gap: 1rem;"></div>
      <div class="text-center mt-8">
        <a href="/" class="btn btn-primary btn-pill">Crea tu LinkPeru gratis</a>
      </div>
      <div class="text-center mt-6">
        <a href="/" class="logo" style="justify-content: center; color: var(--color-text-muted);">
          <div class="logo-icon" style="width: 1.5rem; height: 1.5rem;"></div>
          <span style="font-size: 1rem;">LinkPeru</span>
        </a>
      </div>
    </div>
  </div>
</Base>

<style>
  .profile-link {
    display: block; background: white; border-radius: 1rem; padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow); border: 2px solid transparent; transition: all 0.3s; cursor: pointer;
  }
  .profile-link:hover {
    border-color: var(--color-primary-light); background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent-light));
    transform: translateY(-2px); box-shadow: var(--shadow-lg);
  }
  .profile-link-inner { display: flex; align-items: center; gap: 1rem; }
  .profile-link-icon { font-size: 1.5rem; }
  .profile-link-title { font-weight: 600; flex: 1; }
  .profile-link-arrow { color: var(--color-text-muted); transition: transform 0.2s; }
  .profile-link:hover .profile-link-arrow { transform: translateX(4px); color: var(--color-primary); }
</style>

<script is:inline>
  const slug = window.location.pathname.replace(/^\//, '').replace(/\/$/, '');

  if (slug && slug !== '404') {
    loadProfile(slug);
  } else {
    document.getElementById('loading').classList.add('hidden');
    document.getElementById('notFound').classList.remove('hidden');
  }

  async function loadProfile(slug) {
    try {
      const res = await fetch(`/api/pages/${slug}`);
      if (!res.ok) throw new Error();
      const data = await res.json();

      document.getElementById('loading').classList.add('hidden');
      document.getElementById('profile').classList.remove('hidden');
      document.getElementById('profileName').textContent = data.user.name;
      document.getElementById('profileBio').textContent = data.user.bio || '';
      document.getElementById('avatar').textContent = data.user.name.charAt(0).toUpperCase();
      document.title = `${data.user.name} | LinkPeru`;

      const container = document.getElementById('linksContainer');
      container.innerHTML = data.links.map(l => `
        <a href="${l.url}" target="_blank" rel="noopener" class="profile-link" onclick="trackClick('${l.id}')">
          <div class="profile-link-inner">
            <span class="profile-link-icon">${getIcon(l.url)}</span>
            <span class="profile-link-title">${l.title}</span>
            <span class="profile-link-arrow">→</span>
          </div>
        </a>
      `).join('');

      document.getElementById('shareBtn').addEventListener('click', async () => {
        const url = window.location.href;
        if (navigator.share) { try { await navigator.share({ title: data.user.name, url }); return; } catch {} }
        await navigator.clipboard.writeText(url);
        document.getElementById('shareBtn').textContent = '✅ ¡Copiado!';
        setTimeout(() => { document.getElementById('shareBtn').textContent = '📤 Compartir'; }, 2000);
      });
    } catch {
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('notFound').classList.remove('hidden');
    }
  }

  function trackClick(id) { fetch(`/api/pages/click/${id}`, { method: 'POST' }).catch(() => {}); }

  function getIcon(url) {
    const u = url.toLowerCase();
    if (u.includes('wa.me') || u.includes('whatsapp')) return '💬';
    if (u.includes('instagram')) return '📸';
    if (u.includes('tiktok')) return '🎵';
    if (u.includes('facebook')) return '👥';
    if (u.includes('youtube')) return '▶️';
    if (u.includes('maps.google')) return '📍';
    return '🔗';
  }
</script>
